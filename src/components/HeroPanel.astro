---
import { SITE } from '../consts';
---

<section class="hero card">
	<div class="hero__copy">
		<span class="eyebrow">TARO Communication</span>
		<h1 class="page-title">芋头通讯</h1>
		<p class="hero__subtitle">
			你好，我是 Sean “Taro” Wang，也就是芋头王。这里收纳我对产品、生活与记忆发出的
			一封封通讯。
		</p>

		<div class="hero__actions">
			<a class="button-link" href="#latest">看最新文章</a>
			<a class="button-link secondary" href="/about">认识一下 TARO</a>
		</div>
	</div>

	<div class="hero__profile">
		<div class="hero__avatar" aria-hidden="true">
			<span>T</span>
		</div>
		<p class="hero__label">头像位已预留</p>
		<p class="hero__note">{SITE.description}</p>
	</div>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(16rem, 0.7fr);
		gap: 1.5rem;
		padding: clamp(1.4rem, 3vw, 2.2rem);
		min-height: 30rem;
	}

	.hero__copy {
		align-self: end;
	}

	.hero__subtitle {
		max-width: 42rem;
		font-size: 1.08rem;
		line-height: 1.95;
		color: var(--text-muted);
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.hero__profile {
		display: grid;
		align-content: start;
		justify-items: center;
		gap: 0.8rem;
		padding: 1.5rem;
		background:
			linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.28)),
			linear-gradient(135deg, var(--accent-soft), var(--highlight-soft));
		border-radius: calc(var(--radius-lg) - 6px);
	}

	.hero__avatar {
		display: grid;
		place-items: center;
		width: min(100%, 15rem);
		aspect-ratio: 3 / 4;
		border-radius: 999px 999px 2rem 2rem;
		background:
			radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.7), transparent 18%),
			linear-gradient(135deg, var(--accent), var(--highlight));
		color: var(--accent-contrast);
		font-family: var(--font-sans);
		font-size: 4rem;
	}

	.hero__label,
	.hero__note {
		margin: 0;
		text-align: center;
	}

	.hero__label {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	.hero__note {
		max-width: 18rem;
		line-height: 1.8;
		color: var(--text-muted);
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: unset;
		}

		.hero__profile {
			justify-items: start;
		}

		.hero__note,
		.hero__label {
			text-align: left;
		}
	}
</style>

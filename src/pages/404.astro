---
import Layout from '../layouts/Layout.astro';
---

<Layout title="页面走散了 | 芋头通讯" description="这个页面暂时不存在。">
	<section class="shell not-found">
		<div class="card not-found__card">
			<p class="eyebrow">404</p>
			<h1 class="page-title">这封通讯暂时没找到</h1>
			<p class="lede">也许它还没写好，也许只是地址写错了。先回首页，再继续往前走。</p>
			<a class="button-link" href="/">返回首页</a>
		</div>
	</section>
</Layout>

<style>
	.not-found {
		padding: 4rem 0;
	}

	.not-found__card {
		padding: 2rem;
	}
</style>

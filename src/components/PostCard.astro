---
import { CATEGORY_META } from '../consts';
import type { Post } from '../lib/posts';

interface Props {
	post: Post;
	compact?: boolean;
}

const { post, compact = false } = Astro.props;
const category = CATEGORY_META[post.data.category];
---

<article class:list={['post-card card', compact && 'post-card--compact']}>
	<div class="post-card__meta">
		<span class="pill">{category.label}</span>
		<time datetime={post.data.pubDate.toISOString()}>
			{post.data.pubDate.toLocaleDateString('zh-CN', {
				year: 'numeric',
				month: 'long',
				day: 'numeric',
			})}
		</time>
	</div>

	<h3>
		<a href={`/posts/${post.slug}/`}>{post.data.title}</a>
	</h3>
	<p>{post.data.description}</p>

	<div class="post-card__footer">
		<div class="post-card__tags">
			{post.data.tags.slice(0, compact ? 2 : 4).map((tag) => (
				<span>#{tag}</span>
			))}
		</div>
		<a href={`/posts/${post.slug}/`}>阅读全文</a>
	</div>
</article>

<style>
	.post-card {
		padding: 1.4rem;
	}

	.post-card__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.8rem;
		color: var(--text-muted);
		font-size: 0.88rem;
	}

	.post-card h3 {
		margin: 1rem 0 0.7rem;
		font-family: var(--font-sans);
		font-size: clamp(1.45rem, 2vw, 2rem);
		letter-spacing: -0.03em;
	}

	.post-card h3 a {
		text-decoration: none;
	}

	.post-card p {
		margin: 0;
		line-height: 1.8;
		color: var(--text-muted);
	}

	.post-card__footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		margin-top: 1.2rem;
	}

	.post-card__footer a {
		text-decoration: none;
		font-weight: 600;
	}

	.post-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		color: var(--text-muted);
		font-size: 0.88rem;
	}

	.post-card--compact h3 {
		font-size: 1.2rem;
	}
</style>
